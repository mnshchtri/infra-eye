# Server
PORT=8080
ENV=development

# Database
DB_DSN=postgresql://infraeye:infraeye123@localhost:5432/infraeye?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379

# JWT
JWT_SECRET=change-me-in-production-super-secret-key

# AI (optional — leave empty to use mock responses)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Notifications
GOOGLE_CHAT_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Metrics collection interval in seconds
METRICS_INTERVAL=30

# Log streaming max lines
LOG_MAX_LINES=500
