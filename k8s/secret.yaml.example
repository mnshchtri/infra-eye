# ─────────────────────────────────────────────────────────────────────────────
#  InfraEye — Secret template
#  DO NOT commit the real secret.yaml — it is in .gitignore.
#  The install-k8s.sh script generates the real secret from user input.
#
#  To create manually:
#    cp k8s/secret.yaml.example k8s/secret.yaml
#    # Edit k8s/secret.yaml with real values
#    kubectl apply -f k8s/secret.yaml
# ─────────────────────────────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: infra-eye-secrets
  namespace: infra-eye
type: Opaque
stringData:
  # REQUIRED: Generate with: openssl rand -hex 32
  JWT_SECRET: "CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

  # REQUIRED: Postgres credentials
  DB_PASSWORD: "infraeye123"
  DB_DSN: "postgresql://infraeye:infraeye123@postgres:5432/infraeye?sslmode=disable"

  # OPTIONAL: AI provider API keys (fill in at least one for AI features)
  MISTRAL_API_KEY: ""
  GEMINI_API_KEY: ""
  DEEPSEEK_API_KEY: ""
  OPENROUTER_API_KEY: ""

  # OPTIONAL: Notifications
  GOOGLE_CHAT_WEBHOOK_URL: ""
